APP_NAME="Trading Journal API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-api-domain.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=trading_journal
DB_USERNAME=trading
DB_PASSWORD=change-me

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
TRADE_IMAGES_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=trading_journal

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://your-project.vercel.app
CORS_ALLOWED_ORIGIN_PATTERNS=^https://your-project-.*\.vercel\.app$
CORS_SUPPORTS_CREDENTIALS=false
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com,your-project.vercel.app
SANCTUM_STATEFUL_API=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

PRICE_FEED_PROVIDER=cache_then_exchange_rate_api
PRICE_FEED_EXCHANGE_RATE_API_BASE_URL=https://open.er-api.com/v6/latest
PRICE_FEED_EXCHANGE_RATE_API_KEY=
PRICE_FEED_EXCHANGE_RATE_API_TIMEOUT_SECONDS=2
PRICE_FEED_EXCHANGE_RATE_API_BASE_CACHE_TTL_SECONDS=30
PRICE_FEED_SYNTHETIC_SPREAD_BPS=1
