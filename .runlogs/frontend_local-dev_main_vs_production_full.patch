+const props = defineProps<{
+  theme: ThemeMode
+  options: ThemeOption[]
+  saving?: boolean
+}>()
+
+const emit = defineEmits<{
+  (event: 'change-theme', value: ThemeMode): void
+}>()
+
+const model = ref<ThemeMode>(props.theme)
