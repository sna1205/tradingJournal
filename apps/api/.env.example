APP_NAME="Trading Journal API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
ANALYTICS_STARTING_BALANCE=10000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev uses one database only: sqlite.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# For SPA cookie auth, set the shared parent domain in production (example: .example.com).
SESSION_DOMAIN=null
# Must be true in production (HTTPS).
SESSION_SECURE_COOKIE=false
# Use "none" for cross-site SPA + API domains over HTTPS; "lax" is okay for local same-site setups.
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
TRADE_IMAGES_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production must use explicit origins only (no wildcard), e.g.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Include local Vite fallback port 5174 to avoid auth issues when 5173 is taken.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOWED_ORIGIN_PATTERNS=
# Must be true for browser cookie auth.
CORS_SUPPORTS_CREDENTIALS=true

# Include SPA hosts (host[:port]) that should receive stateful Sanctum cookie auth.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:5174,127.0.0.1:5174,localhost,127.0.0.1
SANCTUM_STATEFUL_API=true
ALLOW_SELF_REGISTER=true
LOCAL_DEMO_EMAIL=demo@tradingjournal.local
LOCAL_DEMO_NAME="Local Demo Trader"
# Finite lifetime for any Sanctum personal access tokens (minutes).
SANCTUM_EXPIRATION_MINUTES=120
# TTL for persisted idempotency fingerprints (minutes).
IDEMPOTENCY_TTL_MINUTES=1440

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PRICE_FEED_PROVIDER=cache_then_exchange_rate_api
PRICE_FEED_EXCHANGE_RATE_API_BASE_URL=https://open.er-api.com/v6/latest
PRICE_FEED_EXCHANGE_RATE_API_KEY=
PRICE_FEED_EXCHANGE_RATE_API_TIMEOUT_SECONDS=2
PRICE_FEED_EXCHANGE_RATE_API_BASE_CACHE_TTL_SECONDS=30
PRICE_FEED_SYNTHETIC_SPREAD_BPS=1
